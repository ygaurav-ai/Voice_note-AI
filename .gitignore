# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Android (fully generated)
/android

# iOS — commit source but ignore generated build artifacts
/ios/Pods/
/ios/build/
/ios/DerivedData/
/ios/*.xcworkspace
/ios/Thoughts.xcodeproj/xcuserdata/
/ios/Thoughts.xcodeproj/project.xcworkspace/xcuserdata/
